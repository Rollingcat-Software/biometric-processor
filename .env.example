# ============================================================================
# Biometric Processor API - Environment Variables
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME=Biometric Processor API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8001
WORKERS=4
RELOAD=False

# ============================================================================
# Database Configuration (PostgreSQL with pgvector)
# ============================================================================
# PostgreSQL connection URL (local installation or PaaS DATABASE_URL)
# For local development: use localhost
# For PaaS: this will be overridden by DATABASE_URL environment variable from platform
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biometric_db

# Connection pool settings (auto-detect by default: 0 = auto)
DATABASE_POOL_MIN_SIZE=0
DATABASE_POOL_MAX_SIZE=0

# Enable pgvector for production
USE_PGVECTOR=True

# NOTE: EMBEDDING_DIMENSION must match your FACE_MODEL choice (see below)

# ============================================================================
# Redis Configuration
# ============================================================================
# For local development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SOCKET_TIMEOUT=5

# For PaaS deployment, you can also use REDIS_URL (overrides above settings)
# REDIS_URL=redis://:password@host:port/db

# ============================================================================
# Identity Core API Integration
# ============================================================================
IDENTITY_CORE_API_URL=http://localhost:8080/api/v1
IDENTITY_CORE_API_KEY=dev-api-key-change-in-production
IDENTITY_CORE_API_TIMEOUT=30

# ============================================================================
# Face Recognition Configuration
# ============================================================================
# Pinned to current production values on Hetzner CX43 (CPU-only, 16 GB shared).
#
# IMPORTANT (FINDINGS_2026-04-25 B1): the Settings.validate_ml_cpu_safety
# validator REJECTS heavy detection backends (retinaface / yolov8 /
# yolov11* / yolov12*) and heavy recognition models (ArcFace / VGG-Face /
# GhostFaceNet) at startup unless ALLOW_HEAVY_ML=true is also set. These
# models OOM-crash the CX43 box without a CUDA-capable GPU, so the boot is
# blocked deliberately. Operators on a GPU host must set ALLOW_HEAVY_ML=true.
#
# Facenet512 is in the SOFT tier — boot continues with a logged WARNING
# because production currently uses it.
FACE_DETECTION_BACKEND=mtcnn
FACE_RECOGNITION_MODEL=Facenet512
ALLOW_HEAVY_ML=false

# Legacy aliases (kept for backwards compatibility — prefer the keys above).
FACE_MODEL=VGG-Face
FACE_DETECTOR=opencv
FACE_DETECTOR_BACKEND=opencv
SIMILARITY_METRIC=cosine
SIMILARITY_THRESHOLD=0.6
EMBEDDING_DIMENSION=2622

# Alternative Models (comment/uncomment to switch)
# IMPORTANT: When using pgvector, EMBEDDING_DIMENSION must match your model!

# FACE_MODEL=Facenet512
# EMBEDDING_DIMENSION=512
# SIMILARITY_THRESHOLD=0.4

# FACE_MODEL=ArcFace
# EMBEDDING_DIMENSION=512
# SIMILARITY_THRESHOLD=0.68

# FACE_MODEL=OpenFace
# EMBEDDING_DIMENSION=128
# SIMILARITY_THRESHOLD=0.4

# ============================================================================
# Liveness Model Asset SHA256 Pins
# ============================================================================
# Set in .env.prod so corrupt/tampered model files are caught at startup.
# Empty (default) = check is skipped with a logged WARNING in production.
FACE_LANDMARKER_MODEL_SHA256=
GESTURE_HAND_LANDMARKER_MODEL_SHA256=

# ============================================================================
# Liveness Detection Configuration
# ============================================================================
# Mode: passive (texture-based), active (smile/blink), combined (both)
LIVENESS_MODE=combined
# Default backend for combined mode is enhanced.
# Optional backend override for evaluation / testing:
# enhanced = current default multi-modal backend
# texture = passive-only baseline
# uniface = MiniFASNet anti-spoofing backend
# LIVENESS_BACKEND=enhanced
# Set this to True only if you explicitly want combined mode to fall back to
# UniFace when LIVENESS_BACKEND is not set.
LIVENESS_UNIFACE_DEFAULT_ENABLED=False
LIVENESS_THRESHOLD=70.0
# Threshold calibration workflow:
# 1) Collect labeled JSONL logs with {"label": "real|spoof", "score": <0-100>}
# 2) Run: python scripts/calibrate_threshold.py --logs logs/liveness.jsonl --write-env .env
# 3) Review FAR/FRR/EER output before promoting the new threshold

# Active liveness thresholds (for active/combined modes)
# EAR: Eye Aspect Ratio - lower = eyes closed
# MAR: Mouth Aspect Ratio - higher = smiling
EAR_THRESHOLD=0.25
MAR_THRESHOLD=0.6

# ============================================================================
# Performance Configuration
# ============================================================================
USE_GPU=False
GPU_DEVICE_ID=0
BATCH_SIZE=32
MAX_BATCH_SIZE=64
MAX_IMAGE_SIZE=1920
IMAGE_QUALITY=95

# Threading
MAX_WORKERS=4
THREAD_POOL_SIZE=10

# ============================================================================
# Model Caching
# ============================================================================
MODELS_CACHE_DIR=./models
ENABLE_MODEL_CACHING=True
MODEL_CACHE_TIMEOUT=3600

# ============================================================================
# Image Processing
# ============================================================================
ALIGN_FACES=True
GRAYSCALE=False
ENFORCE_DETECTION=True
MIN_FACE_SIZE=80
FACE_CONFIDENCE_THRESHOLD=0.9

# ============================================================================
# Security
# ============================================================================
API_KEY_HEADER=X-API-Key
API_KEY=dev-api-key-change-in-production
# Frontend is now served from same origin (port 8001)
CORS_ORIGINS=http://localhost:8001,http://localhost:8080

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/biometric-processor.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# Monitoring
# ============================================================================
ENABLE_METRICS=True
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_FACE_RECOGNITION=True
FEATURE_FACE_VERIFICATION=True
FEATURE_LIVENESS_DETECTION=True
FEATURE_BATCH_PROCESSING=True
FEATURE_QUALITY_ASSESSMENT=True
