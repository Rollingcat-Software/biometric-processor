# =============================================================================
# FIVUCSAS Biometric Processor - Demo UI Configuration
# =============================================================================
#
# IMPORTANT: Copy this file to .env.local and update values as needed.
# Never commit .env.local to version control.
#
# Standard Port Configuration (OFFICIAL):
#   - Backend API: 8001 (STANDARD - see PORT_STANDARDS.md)
#   - Frontend UI: 3000 (Next.js default)
#
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# The backend API URL - must match the port where biometric-processor is running
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001

# Alternative: Use separate host/port configuration
# NEXT_PUBLIC_API_HOST=localhost
# NEXT_PUBLIC_API_PORT=8001
# NEXT_PUBLIC_API_PROTOCOL=http
# NEXT_PUBLIC_WS_PROTOCOL=ws

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Biometric Processor Demo"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_PROCTORING=true
NEXT_PUBLIC_ENABLE_BATCH_PROCESSING=true
NEXT_PUBLIC_ENABLE_WEBHOOKS=true

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_ANALYTICS_ID=
